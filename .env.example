# evm address that receives usdc on arbitrum one
RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# price per request in usdc base units, 6 decimals (10000 = $0.01)
PRICE_USDC=10000

# port the merchant listens on
PORT=4021

# cdp api key id (the "id" field from the cdp json file)
CDP_API_KEY_ID=

# cdp api key private key, ed25519 raw base64 or ec pem (quote multi-line pems)
CDP_PRIVATE_KEY=

# private key of a funded arbitrum one wallet holding usdc (0x-prefixed)
BUYER_PRIVATE_KEY=

# merchant endpoint the buyer pays
RESOURCE_URL=http://localhost:4021/report
