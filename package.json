{
  "name": "x402-arbitrum",
  "version": "0.1.0",
  "private": true,
  "description": "x402 v2 payments on Arbitrum One settled by the Coinbase CDP facilitator: a CLI demo plus an interactive teaching frontend.",
  "author": "Ben Greenberg",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "serve": "pnpm --filter @x402-arbitrum/demo serve",
    "buy": "pnpm --filter @x402-arbitrum/demo buy",
    "web": "pnpm --filter @x402-arbitrum/web dev",
    "web:build": "pnpm --filter @x402-arbitrum/web build",
    "capture-fixtures": "pnpm --filter @x402-arbitrum/demo capture-fixtures",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
